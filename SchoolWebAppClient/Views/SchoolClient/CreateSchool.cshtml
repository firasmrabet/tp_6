@model SchoolWebAppClient.Models.SchoolClient

@{
    ViewData["Title"] = "Créer une école";
}

<div class="form-container">
    <h1 class="form-title">✏️ Créer une école</h1>
    <p class="form-subtitle">Remplissez les informations ci-dessous pour ajouter une nouvelle école</p>

    <form asp-action="CreateSchool" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-group">
            <label asp-for="Name" class="control-label">📛 Nom de l'école</label>
            <input asp-for="Name" class="form-control" placeholder="Ex: École Primaire Saint-Jean" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Sections" class="control-label">📚 Sections</label>
            <input asp-for="Sections" class="form-control" placeholder="Ex: Maternelle, Primaire, Collège" />
            <span asp-validation-for="Sections" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Director" class="control-label">👨‍💼 Directeur/Directrice</label>
            <input asp-for="Director" class="form-control" placeholder="Ex: Jean Dupont" />
            <span asp-validation-for="Director" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Rating" class="control-label">⭐ Note (0-10)</label>
            <input asp-for="Rating" class="form-control" type="number" step="0.1" min="0" max="10" placeholder="Ex: 8.5" />
            <span asp-validation-for="Rating" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="WebSite" class="control-label">🌐 Site Web</label>
            <input asp-for="WebSite" class="form-control" placeholder="Ex: https://example.com" type="url" />
            <span asp-validation-for="WebSite" class="text-danger"></span>
        </div>

        <div class="btn-group">
            <button type="submit" class="btn btn-primary">
                ✅ Créer l'école
            </button>
            <a asp-action="GetAllSchools" class="btn btn-secondary">
                ❌ Annuler
            </a>
        </div>
    </form>

    <div class="form-link">
        <a asp-action="GetAllSchools">← Retour à la liste</a>
    </div>
</div>
</div>
