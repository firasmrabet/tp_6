@model IEnumerable<SchoolWebAppClient.Models.SchoolClient>

@{
    ViewData["Title"] = "Recherche par nom";
}

<h1>Recherche par nom</h1>
<p>Resultats pour : <strong>@ViewBag.SearchTerm</strong></p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Sections</th>
            <th>Director</th>
            <th>Rating</th>
            <th>WebSite</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Sections</td>
                <td>@item.Director</td>
                <td>@item.Rating</td>
                <td>@item.WebSite</td>
                <td>
                    <a asp-action="GetSchoolById" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<p><a asp-action="GetAllSchools" class="btn btn-secondary">Retour a la liste complete</a></p>
