@model SchoolWebAppClient.Models.SchoolClient

@{
    ViewData["Title"] = "Supprimer l'ecole";
}

<h1>Supprimer</h1>

<h3>Voulez-vous vraiment supprimer cette ecole ?</h3>
<div>
    <h4>Ecole</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Name)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Sections)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Sections)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Director)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Director)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Rating)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Rating)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.WebSite)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.WebSite)</dd>
    </dl>

    <form asp-action="DeleteSchool" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Supprimer" class="btn btn-danger" />
        <a asp-action="GetAllSchools" class="btn btn-secondary">Annuler</a>
    </form>
</div>
